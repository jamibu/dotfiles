{
    "layer": "top",
    "position": "top",
    "height": 30,

    "spacing": 2,

    "modules-left": [
        "image#orygen",
        "custom/separator#dot-line",
        "clock",
    ],
    "modules-center": [
        "hyprland/workspaces"
    ],
    "modules-right": [
        "tray",
        "custom/pacman",
        "custom/separator#dot-line",
        "cpu",
        "memory",
        "custom/storage",
        "custom/separator#dot-line",
        "network",
        "wireplumber",
    ],
    "hyprland/workspaces": {
        "format": "{icon}",
		"format-icons": {
			"1": "ΎΖς",
			"2": "ΎΗ╝",
			"3": "ΎΙθ",
			"4": "ίδδ",
			"5": "≤░ΗΞ",
			"6": "ΎΕι",
			"7": "ΎΚσ",
			"8": "ΎΘΑ",
			"9": "ϊ╣ζ",
			"10": "ίΞΒ",
		},
        "disable-scroll": true
    },
    "hyprland/window": {
        "max-length": 80,
        "tooltip": false
    },
    "image#orygen": {
        "path": "/home/jack/.config/waybar/orygen-logo.svg",
        "size": 30,
        "on-click": "wlogout",
    },
    "image#dog": {
        "path": "/home/jackb/.config/waybar/dog.svg",
        "size": 24,
        "on-click": "wlogout",
    },
    "clock": {
        "format": "ΎΒ│ {:%a %d %b ≤░ξΦ %H:%M}",
        "format-alt": "≤░ξΦ {:%H:%M}",
        "format-alt": "ΎΒ│ {:%a %d %b ≤░ξΦ %H:%M}",
        "format-alt-click": "click-right",
        "tooltip-format": "ΎΒ│ {:%a %d %b ≤░ξΦ %H:%M:%S}"
    },
    "battery": {
        "format": "{time} {icon}",
        "format-alt": "{capacity}% {icon}",
        "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"],
        "format-charging": "{capacity}% ≤░ΓΘ",
        "interval": 30,
        "states": {
            "warning": 25,
            "critical": 10
        },
        "tooltip": false
    },
	"backlight": {
        "format": "{icon}",
        "format-alt": "{icon} {percent}%",
        "format-icons": ["ΏθΤκ"],
        "on-scroll-down": "light -A 10%",
        "on-scroll-up": "light -U 10%"
    },
    "wireplumber": {
        "on-click": "pavucontrol",
        "on-click-right": "amixer sset Master toggle 1>/dev/null",
        //on-click: "${wpctl} set-mute @DEFAULT_AUDIO_SINK@ toggle";
        //on-scroll-down: "${wpctl} set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 0.04+";
        //on-scroll-up: "${wpctl} set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 0.04-";
        "format": "<span foreground='#fab387'>{icon}</span> {volume}%",
        "format-muted": "Ό╗ρ ",
        "format-source": "ΎΕ░",
        "format-source-muted": "ΎΕ▒",
        //"format-muted": "<span foreground='#fab387'>ΎΣο </span>",
        //"format-icons": [ "<span foreground='#fab387'>ΎΑρ</span>" ]
        "format-icons": {
            "headphone": "ΎΑξ ",
            "hands-free": "ΎΨΡ ",
            "headset": "ΎΨΡ ",
            "phone": "ΎΓΧ ",
            "portable": "ΎΓΧ ",
            "car": "ΎΗ╣ ",
            "default": ["ΎΑο ", "ΎΑπ ", "ΎΑρ "]
        },
        "min-length": 7,
        "max-length": 7,
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "ΎΑμ",
            "deactivated": "Όφ┤"
        },
        "tooltip": false
    },
    "tray": {
        "icon-size": 18,
        "spacing": 10
    },
    "memory": {
        "interval": 30,
        "format": "ΎΔΚ {}%",
        "format-alt": "ΎΔΚ {used:0.2f}/{total:0.0f}GB",
        "format-alt-click": "click-right",
        "on-click": "alacritty -e btop",
        "min-length": 6,
    },
    "cpu": {
        "interval": 30,
        "format": "ΎΜδ {usage}%",
        "format-alt": "ΎΜδ {max_frequency}GHz<span color=\"darkgray\">|{usage}%</span>",
        "format-alt-click": "click-right",
        "min-length": 5,
        "expand": false,
    },
    "network": {
        "format-wifi": "ΎΘτ  {signalStrength}%",
        "format-ethernet": "{ifname}: {ipaddr}/{cidr} ΎηΨ",
        "format-linked": "{ifname} (No IP) ΎηΨ",
        "format": "ΎΑΤ",
        "format-disconnected": "ΎγΦ",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "format-alt-click": "click-right",
        "on-click": "wl-copy $(ip address show up scope global | grep inet | head -n1 | cut -d/ -f 1 | tr -d [:space:] | cut -c5-)",
        "on-click-right": "wl-copy $(ip address show up scope global | grep inet6 | head -n1 | cut -d/ -f 1 | tr -d [:space:] | cut -c6-)",
        "tooltip-format": "ΎΓΥ {bandwidthUpBits} ΎΑβ {bandwidthDownBits}\n{ifname}\n{ipaddr}/{cidr}\n",
        "tooltip-format-wifi": "ΎΘτ  {essid} {frequency}MHz\nStrength: {signaldBm}dBm ({signalStrength}%)\nIP: {ipaddr}/{cidr}\nΎΓΥ {bandwidthUpBits} ΎΑβ {bandwidthDownBits}",
        "interval": 10,
        "min-length": 7,
        "max-length": 7,
    },
    "custom/storage": {
        "format": "ΎΓι {percentage}%",
        "format-alt": "ΎΓι {}",
        "format-alt-click": "click-right",
        "return-type": "json",
        "interval": 60,
        "exec": "~/.config/waybar/scripts/storage.sh",
    },
    "custom/pacman": {
        "format": "{} ΎΗΘ",
        "interval": 3600,                     // every hour
        "exec": "checkupdates | wc -l",       // # of updates
        "exec-if": "exit 0",                  // always run; consider advanced run conditions
        "signal": 8
    },
    "custom/weather": {
        "exec": "${HOME}/.config/waybar/scripts/get_weather.sh Melbourne+Australia",
        "return-type": "json",
        "format": "{}",
        "tooltip": true,
        "interval": 3600
    },
    "custom/spotify": {
        "exec": "~/.config/waybar/scripts/mediaplayer.py --player spotify",
        "format": "Όακ {} ΎΗ╝ ",
        "return-type": "json",
        "on-click": "playerctl play-pause",
        "on-scroll-up": "playerctl next",
        "on-scroll-down": "playerctl previous"
    },
    "custom/wlogout": {
        "format": "ΎΑΣ",
        "on-click": "wlogout",
    },
    "custom/separator#dot": {
        "format": "ΎΣΕ",
        "interval": "once",
        "tooltip": false
    },
    "custom/separator#dot-line": {
        "format": "Όακ",
        "interval": "once",
        "tooltip": false
    },
    "custom/separator#line": {
        "format": "|",
        "interval": "once",
        "tooltip": false
    },
    "custom/separator#blank": {
        "format": "",
        "interval": "once",
        "tooltip": false
    },
    "custom/separator#blank_2": {
        "format": "  ",
        "interval": "once",
        "tooltip": false
    },
    "custom/separator#blank_3": {
        "format": "   ",
        "interval": "once",
        "tooltip": false
    },
}
