{
    "layer": "top",
    "position": "top",
    "height": 30,

    "spacing": 2,

    "modules-left": [
        "image#orygen",
        "custom/separator#dot-line",
        "clock",
    ],
    "modules-center": [
        "hyprland/workspaces"
    ],
    "modules-right": [
        "tray",
        "custom/separator#dot-line",
        "cpu",
        "memory",
        "custom/storage",
        "custom/separator#dot-line",
        "network",
        "wireplumber",
    ],
    "hyprland/workspaces": {
        "format": "{icon}",
		"format-icons": {
			"1": "´à¬",
			"2": "´å╝",
			"3": "´êş",
			"4": "Õøø",
			"5": "¾░åı",
			"6": "´äá",
			"7": "´ë®",
			"8": "´çÇ",
			"9": "õ╣Ø",
			"10": "Õıü",
		},
        "disable-scroll": true
    },
    "hyprland/window": {
        "max-length": 80,
        "tooltip": false
    },
    "image#orygen": {
        "path": "/home/jack/.config/waybar/orygen-logo.svg",
        "size": 30,
        "on-click": "wlogout",
    },
    "image#dog": {
        "path": "/home/jackb/.config/waybar/dog.svg",
        "size": 24,
        "on-click": "wlogout",
    },
    "clock": {
        "format": "´ü│ {:%a %d %b ¾░Ñö %H:%M}",
        "format-alt": "¾░Ñö {:%H:%M}",
        "format-alt": "´ü│ {:%a %d %b ¾░Ñö %H:%M}",
        "format-alt-click": "click-right",
        "tooltip-format": "´ü│ {:%a %d %b ¾░Ñö %H:%M:%S}"
    },
    "battery": {
        "format": "{time} {icon}",
        "format-alt": "{capacity}% {icon}",
        "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"],
        "format-charging": "{capacity}% ¾░éç",
        "interval": 30,
        "states": {
            "warning": 25,
            "critical": 10
        },
        "tooltip": false
    },
	"backlight": {
        "format": "{icon}",
        "format-alt": "{icon} {percent}%",
        "format-icons": ["­şÆí"],
        "on-scroll-down": "light -A 10%",
        "on-scroll-up": "light -U 10%"
    },
    "wireplumber": {
        "on-click": "pavucontrol",
        "on-click-right": "amixer sset Master toggle 1>/dev/null",
        //on-click: "${wpctl} set-mute @DEFAULT_AUDIO_SINK@ toggle";
        //on-scroll-down: "${wpctl} set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 0.04+";
        //on-scroll-up: "${wpctl} set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 0.04-";
        "format": "<span foreground='#fab387'>{icon}</span> {volume}%",
        "format-muted": "¯╗¿ ",
        "format-source": "´ä░",
        "format-source-muted": "´ä▒",
        //"format-muted": "<span foreground='#fab387'>´æĞ </span>",
        //"format-icons": [ "<span foreground='#fab387'>´Ç¿</span>" ]
        "format-icons": {
            "headphone": "´ÇÑ ",
            "hands-free": "´ûÉ ",
            "headset": "´ûÉ ",
            "phone": "´éò ",
            "portable": "´éò ",
            "car": "´å╣ ",
            "default": ["´ÇĞ ", "´Çğ ", "´Ç¿ "]
        },
        "min-length": 7,
        "max-length": 7,
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "´Çú",
            "deactivated": "¯¡┤"
        },
        "tooltip": false
    },
    "tray": {
        "icon-size": 18,
        "spacing": 10
    },
    "memory": {
        "interval": 30,
        "format": "´âë {}%",
        "format-alt": "´âë {used:0.2f}/{total:0.0f}GB",
        "format-alt-click": "click-right",
        "on-click": "alacritty -e btop",
        "min-length": 6,
    },
    "cpu": {
        "interval": 30,
        "format": "´ïø {usage}%",
        "format-alt": "´ïø {max_frequency}GHz<span color=\"darkgray\">|{usage}%</span>",
        "format-alt-click": "click-right",
        "min-length": 5,
        "expand": false,
    },
    "network": {
        "format-wifi": "´ç½  {signalStrength}%",
        "format-ethernet": "{ifname}: {ipaddr}/{cidr} ´Şû",
        "format-linked": "{ifname} (No IP) ´Şû",
        "format": "´ÇÆ",
        "format-disconnected": "´Üö",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "format-alt-click": "click-right",
        "on-click": "wl-copy $(ip address show up scope global | grep inet | head -n1 | cut -d/ -f 1 | tr -d [:space:] | cut -c5-)",
        "on-click-right": "wl-copy $(ip address show up scope global | grep inet6 | head -n1 | cut -d/ -f 1 | tr -d [:space:] | cut -c6-)",
        "tooltip-format": "´éô {bandwidthUpBits} ´ÇÖ {bandwidthDownBits}\n{ifname}\n{ipaddr}/{cidr}\n",
        "tooltip-format-wifi": "´ç½  {essid} {frequency}MHz\nStrength: {signaldBm}dBm ({signalStrength}%)\nIP: {ipaddr}/{cidr}\n´éô {bandwidthUpBits} ´ÇÖ {bandwidthDownBits}",
        "interval": 10,
        "min-length": 7,
        "max-length": 7,
    },
    "custom/storage": {
        "format": "´éá {percentage}%",
        "format-alt": "´éá {}",
        "format-alt-click": "click-right",
        "return-type": "json",
        "interval": 60,
        "exec": "~/.config/waybar/scripts/storage.sh",
    },
    "custom/weather": {
        "exec": "${HOME}/.config/waybar/scripts/get_weather.sh Melbourne+Australia",
        "return-type": "json",
        "format": "{}",
        "tooltip": true,
        "interval": 3600
    },
    "custom/spotify": {
        "exec": "~/.config/waybar/scripts/mediaplayer.py --player spotify",
        "format": "¯İí {} ´å╝ ",
        "return-type": "json",
        "on-click": "playerctl play-pause",
        "on-scroll-up": "playerctl next",
        "on-scroll-down": "playerctl previous"
    },
    "custom/wlogout": {
        "format": "´Çæ",
        "on-click": "wlogout",
    },
    "custom/separator#dot": {
        "format": "´æä",
        "interval": "once",
        "tooltip": false
    },
    "custom/separator#dot-line": {
        "format": "¯İí",
        "interval": "once",
        "tooltip": false
    },
    "custom/separator#line": {
        "format": "|",
        "interval": "once",
        "tooltip": false
    },
    "custom/separator#blank": {
        "format": "",
        "interval": "once",
        "tooltip": false
    },
    "custom/separator#blank_2": {
        "format": "  ",
        "interval": "once",
        "tooltip": false
    },
    "custom/separator#blank_3": {
        "format": "   ",
        "interval": "once",
        "tooltip": false
    },
}
